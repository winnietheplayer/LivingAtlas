<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="LivingAtlas.Desktop.Views.ConfirmationDialog"
        Title="Confirm"
        Width="400" Height="150"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <StackPanel Margin="20" Spacing="20">
        <TextBlock Name="MessageTextBlock" TextWrapping="Wrap" FontSize="14"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0">
            <Button Name="CancelButton" Content="Cancel" Click="CancelButton_Click" Width="80" HorizontalContentAlignment="Center"/>
            <Button Name="ConfirmButton" Content="Delete" Click="ConfirmButton_Click" Width="80" HorizontalContentAlignment="Center" Classes="accent"/>
        </StackPanel>
    </StackPanel>
</Window>
