<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LivingAtlas.Desktop.ViewModels"
        x:Class="LivingAtlas.Desktop.Views.EditMapSettingsDialog"
        x:DataType="vm:EditMapSettingsViewModel"
        Title="Map Settings"
        Width="560" Height="620"
        MinWidth="560" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <Grid RowDefinitions="*,Auto">
        <ScrollViewer Grid.Row="0" Margin="20,20,20,0">
            <StackPanel Spacing="10">
                <TextBlock Text="Map Name" FontWeight="SemiBold"/>
                <TextBox Text="{Binding Name, Mode=TwoWay}"/>

                <Grid ColumnDefinitions="*,10,*" RowDefinitions="Auto,Auto">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Width (units)" FontWeight="SemiBold"/>
                    <NumericUpDown Grid.Row="1" Grid.Column="0" Value="{Binding Width}" Minimum="1"/>

                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Height (units)" FontWeight="SemiBold"/>
                    <NumericUpDown Grid.Row="1" Grid.Column="2" Value="{Binding Height}" Minimum="1"/>
                </Grid>

                <TextBlock Text="Scale Type" FontWeight="SemiBold"/>
                <ComboBox ItemsSource="{Binding ScaleTypes}"
                          SelectedItem="{Binding ScaleType}"
                          HorizontalAlignment="Stretch"/>

                <TextBlock Text="Feet Per Unit" FontWeight="SemiBold"/>
                <NumericUpDown Value="{Binding FeetPerUnit}" Minimum="0.1" Increment="1"/>

                <StackPanel Spacing="3">
                    <TextBlock Text="Local size:"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding LocalSizeText}"/>
                    <TextBlock Text="Scale:"
                               FontWeight="SemiBold"
                               Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding ScaleText}"/>
                    <TextBlock Text="Represents:"
                               FontWeight="SemiBold"
                               Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding RepresentedSizeText}"/>
                </StackPanel>

                <Separator Margin="0,10"/>
                
                <CheckBox Content="Enable Grid" IsChecked="{Binding GridEnabled}"/>
                
                <TextBlock Text="Grid Cell Size (units)" FontWeight="SemiBold"/>
                <NumericUpDown Value="{Binding GridCellSize}" Minimum="0.1" Increment="0.5"
                               IsEnabled="{Binding GridEnabled}"/>

                <CheckBox Content="Snap to Grid" IsChecked="{Binding SnapToGrid}"
                          IsEnabled="{Binding GridEnabled}"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="10"
                    Margin="20,16,20,20">
            <Button Content="Cancel"
                    Click="Cancel_Click"
                    IsCancel="True"/>
            <Button Content="OK"
                    Click="Ok_Click"
                    Classes="accent"
                    IsDefault="True"
                    IsEnabled="{Binding CanApply}"/>
        </StackPanel>
    </Grid>
</Window>
