<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LivingAtlas.Desktop.ViewModels"
        x:Class="LivingAtlas.Desktop.Views.EditMapSettingsDialog"
        x:DataType="vm:EditMapSettingsViewModel"
        Title="Map Settings"
        Width="400" Height="450"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <StackPanel Margin="20" Spacing="10">
        <TextBlock Text="Map Name" FontWeight="SemiBold"/>
        <TextBox Text="{Binding Name, Mode=TwoWay}"/>

        <Grid ColumnDefinitions="*,10,*" RowDefinitions="Auto,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Width (m)" FontWeight="SemiBold"/>
            <NumericUpDown Grid.Row="1" Grid.Column="0" Value="{Binding Width}" Minimum="1"/>

            <TextBlock Grid.Row="0" Grid.Column="2" Text="Height (m)" FontWeight="SemiBold"/>
            <NumericUpDown Grid.Row="1" Grid.Column="2" Value="{Binding Height}" Minimum="1"/>
        </Grid>

        <TextBlock Text="Scale Type" FontWeight="SemiBold"/>
        <ComboBox ItemsSource="{Binding ScaleTypes}"
                  SelectedItem="{Binding ScaleType}"
                  HorizontalAlignment="Stretch"/>

        <Separator Margin="0,10"/>
        
        <CheckBox Content="Enable Grid" IsChecked="{Binding GridEnabled}"/>
        
        <TextBlock Text="Grid Cell Size (m)" FontWeight="SemiBold"/>
        <NumericUpDown Value="{Binding GridCellSize}" Minimum="0.1" Increment="0.5"
                       IsEnabled="{Binding GridEnabled}"/>

        <CheckBox Content="Snap to Grid" IsChecked="{Binding SnapToGrid}"
                  IsEnabled="{Binding GridEnabled}"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
            <Button Content="Cancel" Click="Cancel_Click"/>
            <Button Content="OK" Click="Ok_Click" Classes="accent"/>
        </StackPanel>
    </StackPanel>
</Window>
