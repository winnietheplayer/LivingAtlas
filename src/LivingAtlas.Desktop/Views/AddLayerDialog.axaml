<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:domain="using:LivingAtlas.Domain.Maps"
        x:Class="LivingAtlas.Desktop.Views.AddLayerDialog"
        Title="Add Layer"
        Width="350" Height="180"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <StackPanel Margin="20" Spacing="15">
        <StackPanel Spacing="5">
            <TextBlock Text="Layer Name:" FontWeight="SemiBold"/>
            <TextBox Name="NameTextBox" PlaceholderText="Enter layer name..."/>
        </StackPanel>

        <StackPanel Spacing="5">
            <TextBlock Text="Layer Type:" FontWeight="SemiBold"/>
            <ComboBox Name="TypeComboBox" HorizontalAlignment="Stretch">
                <!-- Items populated in code-behind -->
            </ComboBox>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0">
            <Button Name="CancelButton" Content="Cancel" Click="CancelButton_Click" Width="80" HorizontalContentAlignment="Center"/>
            <Button Name="OkButton" Content="Add Layer" Click="OkButton_Click" Width="80" HorizontalContentAlignment="Center" Classes="accent"/>
        </StackPanel>
    </StackPanel>
</Window>
