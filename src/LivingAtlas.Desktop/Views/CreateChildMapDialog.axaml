<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LivingAtlas.Desktop.ViewModels"
        x:Class="LivingAtlas.Desktop.Views.CreateChildMapDialog"
        x:DataType="vm:CreateChildMapViewModel"
        Title="Create Child Map"
        Width="400" Height="450"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <StackPanel Margin="20" Spacing="10">
        <TextBlock Text="Map Name" FontWeight="SemiBold"/>
        <TextBox Text="{Binding Name, Mode=TwoWay}"/>

        <TextBlock Text="Scale Type" FontWeight="SemiBold"/>
        <ComboBox ItemsSource="{Binding ScaleTypes}"
                  SelectedItem="{Binding ScaleType}"
                  HorizontalAlignment="Stretch"/>

        <Separator Margin="0,10"/>

        <RadioButton Content="Use District Bounds" IsChecked="{Binding !UseCustomSize}"/>
        <RadioButton Content="Custom Size" IsChecked="{Binding UseCustomSize}"/>

        <Grid ColumnDefinitions="*,10,*" RowDefinitions="Auto,Auto" IsEnabled="{Binding UseCustomSize}">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Width (m)" FontWeight="SemiBold"/>
            <NumericUpDown Grid.Row="1" Grid.Column="0" Value="{Binding Width}" Minimum="1"/>

            <TextBlock Grid.Row="0" Grid.Column="2" Text="Height (m)" FontWeight="SemiBold"/>
            <NumericUpDown Grid.Row="1" Grid.Column="2" Value="{Binding Height}" Minimum="1"/>
        </Grid>

        <CheckBox Content="Open after creation" IsChecked="{Binding OpenAfterCreation}"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
            <Button Content="Cancel" Click="Cancel_Click"/>
            <Button Content="Create" Click="Ok_Click" Classes="accent"/>
        </StackPanel>
    </StackPanel>
</Window>
